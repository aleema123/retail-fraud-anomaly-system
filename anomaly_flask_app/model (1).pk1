    "import numpy as np\n",
    "\n",
    "# Calculate mean and std\n",
    "mean = df['Amount'].mean()\n",
    "std = df['Amount'].std()\n",
    "\n",
    "# Z-score formula\n",
    "df['z_score'] = (df['Amount'] - mean) / std\n",
    "\n",
    "df.head()"
   ]
  },
