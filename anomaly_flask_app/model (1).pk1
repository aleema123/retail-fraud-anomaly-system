      "Index(['Transaction_ID', 'Total_Items', 'Total_Cost'], dtype='object')\n"
     ]
    }
   ],
   "source": [
    "numeric_cols = df.select_dtypes(include=np.number).columns\n",
    "print(numeric_cols)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "015fd2bf-5d4d-4f1b-b80a-5b2902c56147",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Selected Column: Transaction_ID\n"
     ]
    }
   ],
   "source": [
    "amount_col = numeric_cols[0]\n",
    "print(\"Selected Column:\", amount_col)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "ad391a9c-1934-4927-9483-d2e55cac46e0",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Mean: 1000499999.5\n",
      "Std Dev: 288675.27893349814\n"
     ]
    }
   ],
   "source": [
    "mean_val = df[amount_col].mean()\n",
    "std_val = df[amount_col].std()\n",
    "\n",
    "print(\"Mean:\", mean_val)\n",
    "print(\"Std Dev:\", std_val)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "51381019-fff5-4f71-a2e3-02d30cb3986f",
   "metadata": {},
   "outputs": [],
   "source": [
    "if std_val == 0:\n",
    "    std_val = 1"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "id": "32caab85-edf9-415f-8d18-66e61ef7e8d0",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "    Z_Score\n",
      "0 -1.732048\n",
      "1 -1.732045\n",
      "2 -1.732041\n",
      "3 -1.732038\n",
      "4 -1.732034\n"
     ]
    }
   ],
   "source": [
    "df[\"Z_Score\"] = (df[amount_col] - mean_val) / std_val\n",
    "print(df[[\"Z_Score\"]].head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 29,
   "id": "488185e9-4faa-4379-bddc-1de5bbc8e971",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[\"Prediction\"] = np.where(abs(df[\"Z_Score\"]) > 3, \"Anomaly\", \"Normal\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 31,
   "id": "595e6c6c-983e-4070-8cd2-d9a0b8dc494c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Prediction\n",
      "Normal    1000000\n",
      "Name: count, dtype: int64\n"
     ]
    }
   ],
   "source": [
    "print(df[\"Prediction\"].value_counts())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 33,
   "id": "993aa1de-eb63-4e90-9d59-0ee36e7f99d3",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
