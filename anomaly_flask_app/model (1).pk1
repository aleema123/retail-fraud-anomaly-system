     ]
    }
   ],
   "source": [
    "total = len(df)\n",
    "anomaly_count = len(df[df[\"Prediction\"] == \"Anomaly\"])\n",
    "normal_count = len(df[df[\"Prediction\"] == \"Normal\"])\n",
    "\n",
    "print(\"Total Records :\", total)\n",
    "print(\"Normal Records :\", normal_count)\n",
    "print(\"Anomaly Records :\", anomaly_count)\n",
    "\n",
    "anomaly_percent = (anomaly_count / total) * 100\n",
    "print(\"Anomaly Percentage :\", round(anomaly_percent,2), \"%\")"
   ]
  },
