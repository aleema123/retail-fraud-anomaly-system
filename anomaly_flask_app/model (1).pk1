  {
   "cell_type": "code",
   "execution_count": 52,
   "id": "fd998049-c25d-4951-b2e1-7bb2b9039e73",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "ML_Prediction\n",
      "Normal     950146\n",
      "Anomaly     49854\n",
      "Name: count, dtype: int64\n"
     ]
    }
   ],
   "source": [
    "from sklearn.ensemble import IsolationForest\n",
    "\n",
    "# Train ML Model\n",
    "ml_model = IsolationForest(\n",
    "    n_estimators=100,\n",
    "    contamination=0.05,\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "# Fit model using selected numeric column\n",
    "ml_model.fit(df[[amount_col]])\n",
    "\n",
    "# Predict\n",
    "# -1 = anomaly, 1 = normal\n",
    "df[\"ML_Prediction\"] = ml_model.predict(df[[amount_col]])\n",
    "\n",
    "# Convert labels\n",
    "df[\"ML_Prediction\"] = df[\"ML_Prediction\"].map({\n",
    "    1: \"Normal\",\n",
    "    -1: \"Anomaly\"\n",
    "})\n",
    "\n",
    "print(df[\"ML_Prediction\"].value_counts())"
   ]
  },
