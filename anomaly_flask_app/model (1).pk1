      "Index: []\n"
     ]
    }
   ],
   "source": [
    "anomalies = df[df[\"Prediction\"] == \"Anomaly\"]\n",
    "print(anomalies)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 35,
   "id": "3b6247ea-a015-4800-9a3a-d89aa247e4f0",
