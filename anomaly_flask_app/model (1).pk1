   "source": [
    "plt.figure(figsize=(12,6))\n",
    "\n",
    "colors = df[\"Prediction\"].map({\n",
    "    \"Normal\": \"blue\",\n",
    "    \"Anomaly\": \"red\"\n",
    "})\n",
    "\n",
    "plt.scatter(df.index, df[amount_col], c=colors, s=50)\n",
    "\n",
    "plt.title(\"Retail Transaction Anomaly Detection\")\n",
    "plt.xlabel(\"Transaction Index\")\n",
    "plt.ylabel(amount_col)\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
